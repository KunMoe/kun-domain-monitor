# Local dev (dotenv) uses these plain names. In Docker/Dokploy, inject the same
# values at runtime with the canonical NUXT_ prefix (e.g. NUXT_KUN_DATABASE_URL,
# NUXT_OAUTH_CLIENT_SECRET) so Nitro maps them into runtimeConfig.

KUN_DATABASE_URL = "postgresql://postgres:kun@localhost:5432/kun_domain_monitor"

REDIS_HOST = '127.0.0.1'
REDIS_PORT = '6379'

# OAuth client against ../kun-galgame-infra. Register an OAuth client with the
# infra admin to obtain CLIENT_ID / CLIENT_SECRET, and register the redirect_uri
# below (must match exactly). Only users whose roles include `ren` may sign in.
#   dev  base: http://127.0.0.1:9277/api/v1
#   prod base: https://oauth.kungal.com/api/v1
OAUTH_SERVER_URL = 'http://127.0.0.1:9277/api/v1'
OAUTH_CLIENT_ID = ''
OAUTH_CLIENT_SECRET = ''
OAUTH_REDIRECT_URI = 'http://localhost:3970/api/auth/callback'
OAUTH_SCOPE = 'openid profile'

# Monitor tuning (all optional; defaults shown).
MONITOR_BATCH_SIZE = '20'
MONITOR_LOOKUP_TIMEOUT_MS = '15000'
# Optional: POST every status-change event to this webhook (Telegram/Slack/etc).
MONITOR_NOTIFY_WEBHOOK = ''

WEBSITE_URL = ''
